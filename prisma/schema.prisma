// ============================================================
// GlaucoBarber – Prisma Schema
// Multi-tenant SaaS for barbershops
// Trinks = operational backend | This app = intelligence layer
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts  Account[]
  sessions  Session[]
  memberships Membership[]
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// MULTI-TENANT CORE
// ============================================================

model Barbershop {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  logoUrl      String?
  websiteUrl   String?
  description  String?
  instagramUrl String?
  brandStyle   String?  // Visual identity description used in campaign image prompts
  campaignReferenceImageUrl String? // Public URL for campaign image reference/base photo

  // Trinks: the operational source of truth
  trinksConfigured Boolean @default(false)

  // Daily gift: first AI suggestion generation of the day is free
  lastDailyGiftAt  DateTime?

  // Dashboard widget preferences: JSON array of up to 3 widget keys
  dashboardWidgets String    @default("[]")

  // Agenda display settings
  agendaStartHour Int @default(6)   // 0–23
  agendaEndHour   Int @default(24)  // 1–24 (exclusive upper bound)

  // Platform subscription (SaaS billing)
  stripeCustomerId String? @unique
  subscription     PlatformSubscription?

  // Relations
  memberships   Membership[]
  integration   Integration?
  syncRuns      SyncRun[]
  customers     Customer[]
  services      Service[]
  appointments  Appointment[]
  offers        Offer[]
  campaigns     Campaign[]
  suggestions   Suggestion[]
  payments      Payment[]
  auditLogs     AuditLog[]
  actions       Action[]
  copilotThreads CopilotThread[]
  whatsappMessages  WhatsappMessage[]
  whatsappTemplates WhatsappTemplate[]
  featureFlags  FeatureFlag[]
  goals         Goal[]
  templates     Template[]
  postSaleActions PostSaleAction[]
  customerReviews CustomerReview[]
  serviceOpportunities ServiceOpportunity[]
  aiUsageMonths       AiUsageMonth[]
  billingEvents       BillingEvent[]
  aiCallLogs          AiCallLog[]
  systemNotifications SystemNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("barbershops")
}

enum MembershipRole {
  PLATFORM_ADMIN
  OWNER
  BARBER
  STAFF
}

model Membership {
  id           String         @id @default(cuid())
  userId       String
  barbershopId String
  role         MembershipRole @default(BARBER)
  active       Boolean        @default(true)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, barbershopId])
  @@map("memberships")
}

// ============================================================
// TRINKS INTEGRATION
// ============================================================

enum IntegrationStatus {
  UNCONFIGURED
  ACTIVE
  ERROR
  PAUSED
}

model Integration {
  id           String            @id @default(cuid())
  barbershopId String            @unique
  provider     String            @default("trinks")
  status       IntegrationStatus @default(UNCONFIGURED)

  // Credentials stored encrypted (use env for encryption key)
  // IMPORTANT: These fields hold provider-specific config.
  // For Trinks: apiKey, companyId, etc.
  // Exact field names depend on Trinks API documentation.
  // See lib/integrations/trinks/types.ts for contract.
  configJson String? // JSON blob, encrypted at app layer

  // Instagram (opcional, para campanhas)
  instagramPageAccessToken String?
  instagramBusinessId      String?
  instagramPageId          String?
  instagramUsername        String?

  // WhatsApp Business API (Meta) – credenciais por barbershop
  whatsappAccessToken   String? // token de acesso permanente da Meta API
  whatsappPhoneNumberId String? // ID do número cadastrado no Meta (phone_number_id)
  whatsappVerifyToken   String? // gerado automaticamente pelo sistema; o usuário só copia no painel Meta
  whatsappWabaId        String? // WhatsApp Business Account ID (para sincronizar templates da Meta)

  lastSyncAt DateTime?
  errorMsg   String?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  syncRuns   SyncRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integrations")
}

// ============================================================
// CAMPAIGN TEMPLATES
// ============================================================

model Template {
  id           String  @id @default(cuid())
  barbershopId String
  name         String
  type         String   @default("post") // post | story
  imageUrl     String
  thumbUrl     String?
  isGlobal     Boolean  @default(false)

  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("templates")
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model SyncRun {
  id           String     @id @default(cuid())
  barbershopId String
  integrationId String?
  status       SyncStatus @default(RUNNING)
  triggeredBy  String?    // userId or "cron"

  // Metrics
  customersUpserted    Int @default(0)
  servicesUpserted     Int @default(0)
  appointmentsUpserted Int @default(0)
  errorsCount          Int @default(0)

  errorDetails String? // JSON array of errors
  durationMs   Int?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?

  barbershop  Barbershop   @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  integration Integration? @relation(fields: [integrationId], references: [id])

  @@map("sync_runs")
}

// ============================================================
// OPERATIONAL DATA (synced from Trinks)
// ============================================================

enum CustomerStatus {
  ACTIVE
  INACTIVE
  VIP
  BLOCKED
}

// Pós-venda / retenção
enum PostSaleStatus {
  RECENTE
  EM_RISCO
  INATIVO
  REATIVADO
  NAO_CONTATAR
}

enum PostSaleChurnReason {
  SEM_INTERESSE
  MUDOU_DE_REGIAO
  PRECO
  CONCORRENTE
  ATENDIMENTO_PONTUAL
  SEM_RETORNO
  OUTRO
}

model Customer {
  id           String         @id @default(cuid())
  barbershopId String
  trinksId     String?        // external ID from Trinks
  name         String
  phone        String?
  email        String?
  birthDate    DateTime?
  notes        String?
  tags         String[]       @default([])
  status       CustomerStatus @default(ACTIVE)
  postSaleStatus PostSaleStatus?
  doNotContact   Boolean        @default(false)
  reviewOptOut   Boolean        @default(false)
  lastCompletedAppointmentAt DateTime?
  nextAppointmentAt          DateTime?
  inactiveAt                 DateTime?
  reactivatedAt              DateTime?
  lastWhatsappSentAt         DateTime?  // updated when a WhatsApp message is queued for this customer
  churnReason   PostSaleChurnReason?
  preferredProfessionalId String?
  avatarUrl    String?

  // Computed/cached fields (refreshed on sync)
  totalVisits   Int      @default(0)
  totalSpent    Decimal  @default(0) @db.Decimal(10, 2)
  lastVisitAt   DateTime?
  firstVisitAt  DateTime?
  avgTicket     Decimal  @default(0) @db.Decimal(10, 2)

  // Last visit summary (refreshed on COMPLETED or sync)
  lastServiceSummary  String?
  lastSpentAmount     Decimal? @db.Decimal(10, 2)

  // Rolling 60-day window (refreshed on COMPLETED or sync)
  totalSpentLast60d   Decimal? @db.Decimal(10, 2)
  visitsLast60d       Int?
  avgTicketLast60d    Decimal? @db.Decimal(10, 2)

  // Source tracking
  syncedFromTrinks  Boolean   @default(false)
  lastSyncedAt      DateTime?
  locallyModifiedAt DateTime? // set when user edits locally — prevents sync from overwriting
  deletedAt         DateTime? // soft delete: set on DELETE; sync skips records where this is non-null

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  payments     Payment[]
  postSaleActions PostSaleAction[]
  customerReviews CustomerReview[]
  whatsappMessages WhatsappMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barbershopId, trinksId])
  @@index([barbershopId, postSaleStatus])
  @@index([barbershopId, lastCompletedAppointmentAt])
  @@index([barbershopId, nextAppointmentAt])
  @@map("customers")
}

model PostSaleAction {
  id             String     @id @default(cuid())
  barbershopId   String
  customerId     String
  appointmentId  String?
  actionType     String
  channel        String
  result         String
  notes          String?
  createdByUserId String?

  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barbershopId, customerId])
  @@index([appointmentId])
  @@map("post_sale_actions")
}

model CustomerReview {
  id             String   @id @default(cuid())
  barbershopId   String
  customerId     String
  appointmentId  String
  requestStatus  String
  requestSentAt  DateTime?
  respondedAt    DateTime?
  reviewedAt     DateTime?
  reviewUrl      String?
  notes          String?

  barbershop   Barbershop  @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment  Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appointmentId])
  @@index([barbershopId, customerId])
  @@map("customer_reviews")
}

enum ServiceCategory {
  HAIRCUT
  BEARD
  COMBO
  TREATMENT
  OTHER
}

model Service {
  id           String          @id @default(cuid())
  barbershopId String
  trinksId     String?
  name         String
  description  String?
  category     ServiceCategory @default(HAIRCUT)
  price        Decimal         @db.Decimal(10, 2)
  durationMin  Int             @default(30)
  active       Boolean         @default(true)
  visible      Boolean         @default(true)

  syncedFromTrinks Boolean  @default(false)
  lastSyncedAt     DateTime?

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  appointmentItems AppointmentItem[]
  offerItems   OfferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barbershopId, trinksId])
  @@map("services")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id           String            @id @default(cuid())
  barbershopId String
  trinksId     String?
  customerId   String?
  serviceId    String?
  barberId     String?           // userId of barber

  scheduledAt DateTime
  durationMin Int              @default(30)
  status      AppointmentStatus @default(SCHEDULED)
  price       Decimal?          @db.Decimal(10, 2)
  notes       String?
  confirmedAt DateTime?
  completedAt DateTime?
  noShowAt    DateTime?

  offerId     String?
  syncedFromTrinks Boolean  @default(false)
  lastSyncedAt     DateTime?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id])
  service    Service?   @relation(fields: [serviceId], references: [id])
  offer      Offer?     @relation(fields: [offerId], references: [id])
  items      AppointmentItem[]
  payments   Payment[]
  postSaleActions PostSaleAction[]
  customerReviews CustomerReview[]
  billingEvent    BillingEvent?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barbershopId, trinksId])
  @@map("appointments")
}

model AppointmentItem {
  id             String   @id @default(cuid())
  appointmentId  String
  serviceId      String?
  name           String
  quantity       Int      @default(1)
  unitPrice      Decimal  @db.Decimal(10, 2)
  totalPrice     Decimal  @db.Decimal(10, 2)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service?    @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointment_items")
}

// ============================================================
// COMMERCIAL / OFFERS
// ============================================================

enum OfferType {
  PACKAGE      // N cortes antecipados
  COMBO        // corte + barba
  SUBSCRIPTION // VIP recorrente
  FLASH_PROMO  // promoção relâmpago
  PREPAID      // crédito pré-pago
}

enum OfferStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

model Offer {
  id           String      @id @default(cuid())
  barbershopId String
  type         OfferType
  status       OfferStatus @default(DRAFT)
  title        String
  description  String?
  originalPrice Decimal    @db.Decimal(10, 2)
  salePrice    Decimal     @db.Decimal(10, 2)
  credits      Int?        // number of sessions in package
  validUntil   DateTime?
  maxRedemptions Int?
  redemptionsCount Int     @default(0)

  // Stripe integration (future: barbershop selling to clients)
  stripeProductId String?
  stripePriceId   String?

  barbershop   Barbershop   @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  payments     Payment[]
  items        OfferItem[]
  appointments Appointment[]
  campaigns    Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offers")
}

model OfferItem {
  id          String  @id @default(cuid())
  offerId     String
  serviceId   String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  discountPct Int     @default(0)

  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@map("offer_items")
}

enum ServiceOpportunityStatus {
  PENDING
  APPROVED
  REJECTED
}

model ServiceOpportunity {
  id                String                   @id @default(cuid())
  barbershopId      String
  name              String
  category          ServiceCategory          @default(HAIRCUT)
  description       String?
  suggestedPrice    Decimal                  @db.Decimal(10, 2)
  rationale         String
  status            ServiceOpportunityStatus @default(PENDING)
  approvedServiceId String?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_opportunities")
}

// ============================================================
// AI SUGGESTIONS & CAMPAIGNS
// ============================================================

enum SuggestionType {
  COMMERCIAL_INSIGHT   // visão do dia
  CAMPAIGN_TEXT        // texto de campanha
  CLIENT_MESSAGE       // mensagem para cliente inativo
  SOCIAL_POST          // post para redes sociais
  PROMO_BRIEFING       // briefing para arte promocional
  OFFER_OPPORTUNITY    // oportunidade de vender pacote
}

enum SuggestionStatus {
  PENDING
  APPROVED
  DISMISSED
  PUBLISHED
  EXECUTED
}

model Suggestion {
  id           String           @id @default(cuid())
  barbershopId String
  type         SuggestionType
  status       SuggestionStatus @default(PENDING)

  title   String
  content String   // main generated text
  reason  String   // why this suggestion was generated
  context String?  // serialized JSON: occupancy, slots, date, etc.

  // If approved, optional action taken
  actionTakenAt DateTime?
  actionNotes   String?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  campaign   Campaign?
  actions    Action[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suggestions")
}

enum CampaignStatus {
  DRAFT
  APPROVED
  DISMISSED
  SCHEDULED
  PUBLISHED
}

model Campaign {
  id           String         @id @default(cuid())
  barbershopId String
  suggestionId String?        @unique
  status       CampaignStatus @default(DRAFT)

  offerId     String?
  title       String
  objective   String
  text        String          // campaign copy
  artBriefing String?         // briefing for visual art
  channel     String?         @default("instagram")
  templateId  String?
  imageUrl    String?
  instagramPostId    String?
  instagramPermalink String?
  scheduledAt DateTime?
  publishedAt DateTime?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  suggestion Suggestion? @relation(fields: [suggestionId], references: [id])
  template   Template?   @relation(fields: [templateId], references: [id])
  offer      Offer?      @relation(fields: [offerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("campaigns")
}

// ============================================================
// COPILOT & ACTIONS
// ============================================================

enum ActionStatus {
  DRAFT
  APPROVED
  EDITED
  DISMISSED
  EXECUTED
}

model Action {
  id            String       @id @default(cuid())
  barbershopId  String
  suggestionId  String?
  title         String
  description   String?
  type          String      // e.g. "campaign", "follow_up", "pricing"
  payload       Json?
  status        ActionStatus @default(DRAFT)
  source        String       @default("ai") // ai | manual
  createdBy     String?
  approvedBy    String?
  executedBy    String?
  executedAt    DateTime?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  suggestion Suggestion? @relation(fields: [suggestionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("actions")
}

enum CopilotThreadStatus {
  OPEN
  ARCHIVED
}

model CopilotThread {
  id             String               @id @default(cuid())
  barbershopId   String
  title          String?
  createdBy      String?
  status         CopilotThreadStatus  @default(OPEN)
  lastMessageAt  DateTime             @default(now())

  barbershop     Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  messages       CopilotMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("copilot_threads")
}

enum CopilotMessageRole {
  USER
  ASSISTANT
  ACTION
}

model CopilotMessage {
  id         String             @id @default(cuid())
  threadId   String
  role       CopilotMessageRole
  content    String
  actionsJson Json?

  thread CopilotThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("copilot_messages")
}

// ============================================================
// WHATSAPP COMMUNICATIONS
// ============================================================

enum WhatsappMessageStatus {
  QUEUED
  SENT
  FAILED
}

model WhatsappMessage {
  id           String                @id @default(cuid())
  barbershopId String
  customerId   String?
  customerName String
  phone        String
  message      String                @db.Text
  type          String                // reactivation | post_sale_review | post_sale_followup | agenda_conflict | general
  // "text" = free text via Business API; "template" = Meta-approved template (HSM)
  messageKind   String                @default("text")
  templateName  String?               // metaName of the WhatsappTemplate used (if messageKind=="template")
  templateVars  String?               // JSON array of resolved variable values e.g. ["João","https://g.page/..."]
  status        WhatsappMessageStatus @default(QUEUED)
  actionId      String?
  scheduledFor  DateTime?             // if set: send only after this date/time
  sentAt        DateTime?
  sentManually  Boolean               @default(false) // true = abriu WhatsApp e enviou manualmente
  metaMessageId String?               // wamid retornado pela Meta API; usado para rastrear delivery status
  errorMessage  String?               // motivo da falha de envio (capturado da API da Meta)

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barbershopId, status])
  @@index([barbershopId, createdAt])
  @@map("whatsapp_messages")
}

// ============================================================
// WHATSAPP TEMPLATES (Meta-approved HSM templates)
// Each barbershop registers their own templates in Meta Business Manager.
// Variables use {{1}}, {{2}} notation in Meta; stored here for preview and UI.
// ============================================================

model WhatsappTemplate {
  id           String  @id @default(cuid())
  barbershopId String
  metaName     String  // exact name in Meta Business Manager (e.g. "review_request"); for "text" kind, auto-generated slug
  label        String  // human-readable label (e.g. "Pedir avaliação Google")
  body         String  // body text with {{1}}, {{2}} for "meta"; {{name}} for "text"
  // JSON array: [{key,label,defaultValue}] — used for "meta" kind variables
  variables    String  @default("[]")
  active       Boolean @default(true)
  kind         String  @default("meta") // "meta" = bot/HSM (requires Meta approval), "text" = manual compose

  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barbershopId, metaName])
  @@map("whatsapp_templates")
}

// ============================================================
// BILLING (Platform SaaS via Stripe)
// ============================================================

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

model PlatformSubscription {
  id            String             @id @default(cuid())
  barbershopId  String             @unique
  stripeSubId   String?            @unique   // null para plano FREE
  stripePriceId String?                      // null para plano FREE
  planTier      PlanTier           @default(FREE)
  status        SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime      @default(now())
  currentPeriodEnd   DateTime      @default(dbgenerated("NOW() + INTERVAL '1 year'"))
  cancelAtPeriodEnd  Boolean       @default(false)
  trialEndsAt        DateTime?

  // Créditos extras de IA comprados (each credit = 1 AI call)
  aiCreditBalance Int @default(0)

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_subscriptions")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentDomain {
  PLATFORM_SUBSCRIPTION  // SaaS fee
  SHOP_OFFER             // barbershop selling to client
  BARBERSHOP_SERVICE     // serviços de agenda
}

model Payment {
  id           String        @id @default(cuid())
  barbershopId String
  customerId   String?       // barbershop's customer (for shop offers)
  offerId      String?
  appointmentId String?
  domain       PaymentDomain
  status       PaymentStatus @default(PENDING)
  amount       Decimal       @db.Decimal(10, 2)
  currency     String        @default("BRL")
  description  String?
  discountValue Decimal?     @db.Decimal(10, 2)
  paidValue     Decimal?     @db.Decimal(10, 2)

  // Stripe refs
  stripePaymentIntentId String?
  stripeChargeId        String?

  paidAt DateTime?

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id])
  offer      Offer?     @relation(fields: [offerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

// ============================================================
// GOALS & FEATURE FLAGS
// ============================================================

model Goal {
  id                String @id @default(cuid())
  barbershopId      String
  month             Int    // 1-12
  year              Int
  revenueTarget     Decimal? @db.Decimal(10, 2)
  appointmentTarget Int?
  notes             String?
  offDaysOfWeek     Int[]    // 0=Dom,1=Seg,...,6=Sab — dias que NÃO trabalha
  extraOffDays      Int[]    // dias específicos (1-31) bloqueados mesmo sendo dia útil
  extraWorkDays     Int[]    // dias específicos (1-31) liberados mesmo sendo folga
  workingDaysCount  Int?     // dias do mês que vai trabalhar (calculado)

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barbershopId, month, year])
  @@map("goals")
}

model FeatureFlag {
  id           String  @id @default(cuid())
  barbershopId String
  flag         String
  enabled      Boolean @default(false)

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([barbershopId, flag])
  @@map("feature_flags")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id           String  @id @default(cuid())
  barbershopId String?
  userId       String?
  action       String  // e.g. "suggestion.approved", "sync.triggered"
  entity       String? // e.g. "Suggestion", "Campaign"
  entityId     String?
  metadata     String? // JSON

  barbershop Barbershop? @relation(fields: [barbershopId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([barbershopId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// AI USAGE & BILLING EVENTS
// ============================================================

// Tracks AI consumption per barbershop per billing period.
// yearMonth = "2024-04" for paid plans; "trial" for FREE (lifetime counter).
model AiUsageMonth {
  id           String @id @default(cuid())
  barbershopId String
  yearMonth    String  // "YYYY-MM" or "trial"
  usageCount   Int    @default(0)

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barbershopId, yearMonth])
  @@map("ai_usage_months")
}

// Per-appointment fee events for PRO plan (R$1,50 each).
// invoicedAt is null until the monthly cron runs and creates Stripe invoice items.
model BillingEvent {
  id            String    @id @default(cuid())
  barbershopId  String
  appointmentId String    @unique  // idempotência: 1 evento por atendimento
  yearMonth     String              // "YYYY-MM"
  amountCents   Int                 // 150 = R$1,50
  invoicedAt    DateTime?           // null = ainda não faturado

  barbershop  Barbershop  @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  createdAt DateTime @default(now())

  @@index([barbershopId, yearMonth, invoicedAt])
  @@map("billing_events")
}

// ============================================================
// PLATFORM CONFIG (admin-managed key-value store)
// Used to store Stripe Price IDs and other platform settings
// without requiring env var redeploys.
// ============================================================

model PlatformConfig {
  key       String   @id  // e.g. "stripe_price_pro_monthly"
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_configs")
}

// ============================================================
// FEATURE GATES — which features each plan/role can access
// Configurable by admin. Per-barbershop override via FeatureFlag.
// ============================================================

model PlanFeatureGate {
  id       String  @id @default(cuid())
  feature  String  // e.g. "financeiro", "campaigns", "copilot"
  // Role or plan tier: FREE | STARTER | PRO | PLATFORM_ADMIN
  planTier String
  enabled  Boolean @default(true)

  @@unique([feature, planTier])
  @@map("plan_feature_gates")
}

// ============================================================
// AI CALL LOG — individual call history per barbershop
// Max 30 records per barbershop (enforced after each insert).
// Cron also purges extras daily.
// ============================================================

model AiCallLog {
  id           String @id @default(cuid())
  barbershopId String
  feature      String // e.g. "copilot_chat", "price_recommend", "campaign_image"
  label        String // human-readable, stored at write time for stability

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([barbershopId, createdAt])
  @@map("ai_call_logs")
}

// ============================================================
// SYSTEM NOTIFICATIONS — bell icon alerts for barbershop owners
// Auto-expire after 30 days (cron cleanup).
// Max retained: driven by cron, no hard insert cap.
// ============================================================

enum NotificationType {
  TRIAL_QUOTA_EXCEEDED
  TRIAL_EXPIRED
  PAYMENT_FAILED
  PLAN_CHANGED
  SYSTEM
}

model SystemNotification {
  id           String           @id @default(cuid())
  barbershopId String
  type         NotificationType
  title        String
  body         String
  dismissed    Boolean          @default(false)

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([barbershopId, dismissed, createdAt])
  @@map("system_notifications")
}
