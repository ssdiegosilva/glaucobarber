# ============================================================
# GlaucoBarber - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="GlaucoBarber"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres.<project_ref>:password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://user:password@db.yourproject.supabase.co:5432/postgres?sslmode=require"

# --- Auth (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Opcional: usar service role em rotas internas
# SUPABASE_SERVICE_ROLE_KEY=ey...

# --- Stripe ---
# Platform SaaS billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (platform subscription plans)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
# One-time AI credits pack (60 créditos — R$29)
STRIPE_PRICE_AI_CREDITS_PACK=price_...
# Metered billing: R$1,00 por atendimento concluído no PRO
STRIPE_PRICE_PRO_METERED=price_...

# --- AI Provider ---
# Default: OpenAI
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
AI_PROVIDER=openai
# Future: anthropic | groq | local

# --- Trinks Integration ---
# These are stored per barbershop in DB, but you can set defaults here
# TRINKS_API_BASE_URL=https://api.trinks.com  # NOT CONFIRMED - set via DB
# TRINKS_DEFAULT_TIMEOUT_MS=10000

# --- Instagram OAuth (Meta Platform App) ---
# Create a Meta App at https://developers.facebook.com with Facebook Login + Instagram Graph API
# Register redirect URI: {NEXT_PUBLIC_APP_URL}/api/integrations/instagram/callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Set to "true" to show the "Entrar com Instagram" OAuth button in Settings
NEXT_PUBLIC_INSTAGRAM_OAUTH_ENABLED=false

# --- Feature Flags ---
FEATURE_AI_SUGGESTIONS=true
FEATURE_CAMPAIGNS=true
FEATURE_OFFERS=true
FEATURE_STRIPE_SHOP_OFFERS=false  # barbershop selling to clients (future)
FEATURE_WHATSAPP=false            # future adapter
FEATURE_INSTAGRAM=false           # future adapter

# --- Cron (Vercel Cron) ---
CRON_SECRET="generate-with: openssl rand -hex 32"

# --- Optional: Email (para notificações separadas) ---
# EMAIL_NOTIFICATIONS_FROM="GlaucoBarber <noreply@glaucobarber.com>"
