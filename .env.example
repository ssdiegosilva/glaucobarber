# ============================================================
# GlaucoBarber - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="GlaucoBarber"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@db.yourproject.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://user:password@db.yourproject.supabase.co:5432/postgres?sslmode=require"

# --- Auth (NextAuth v5) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL=http://localhost:3000

# --- Stripe ---
# Platform SaaS billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (platform subscription plans)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# --- AI Provider ---
# Default: OpenAI
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
AI_PROVIDER=openai
# Future: anthropic | groq | local

# --- Trinks Integration ---
# These are stored per barbershop in DB, but you can set defaults here
# TRINKS_API_BASE_URL=https://api.trinks.com  # NOT CONFIRMED - set via DB
# TRINKS_DEFAULT_TIMEOUT_MS=10000

# --- Feature Flags ---
FEATURE_AI_SUGGESTIONS=true
FEATURE_CAMPAIGNS=true
FEATURE_OFFERS=true
FEATURE_STRIPE_SHOP_OFFERS=false  # barbershop selling to clients (future)
FEATURE_WHATSAPP=false            # future adapter
FEATURE_INSTAGRAM=false           # future adapter

# --- Cron (Vercel Cron) ---
CRON_SECRET="generate-with: openssl rand -hex 32"

# --- Optional: Email (for notifications) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM="GlaucoBarber <noreply@glaucobarber.com>"
